# CarbonIQ AI — Enterprise Environment Variables
# Copy this file to .env and fill in your details.
# DO NOT commit .env to version control!

# ==========================================
# GLOBAL SETTINGS
# ==========================================
NODE_ENV=development

# ==========================================
# BACKEND SERVICES
# ==========================================
PORT=5000
DATABASE_URL=postgresql://carboniq:carboniq_dev@localhost:5432/carboniq_dev
REDIS_URL=redis://localhost:6379

# ==========================================
# MACHINE LEARNING SERVICE
# ==========================================
ML_SERVICE_URL=http://localhost:8000
ML_ENV=development

# ==========================================
# FRONTEND SERVICES
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_TELEMETRY_DISABLED=1

# ==========================================
# SECURITY & AUTHENTICATION
# ==========================================
# Replace these with strong, randomly generated keys in production!
JWT_SECRET=dev_jwt_secret_change_me_in_prod_minimum_32_chars
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_me_in_prod_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# ==========================================
# AI INTEGRATION (Google Gemini)
# ==========================================
# If left blank, the application will automatically fall back to Mock AI responses.
GEMINI_API_KEY=

# ==========================================
# EMAIL NOTIFICATIONS (MailHog for Dev)
# ==========================================
SMTP_HOST=localhost
SMTP_PORT=1025

# Production email configuration (e.g., AWS SES, SendGrid)
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@carboniq.ai
