dist/
build/
.next/
out/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
*.whl
venv/
.venv/
env/
.env.local
.env.development.local
.env.test.local
.env.production.local

# ML Models
ml-service/models/*.joblib
ml-service/models/*.pkl
ml-service/models/*.h5

# Environment files
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/

# Docker
docker-compose.override.yml

# OS
.DS_Store
*.pem

# Misc
*.tgz
.cache/
.turbo/
