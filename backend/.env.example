# ========================================
# CarbonIQ AI — Backend Environment Variables
# ========================================

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://carboniq:carboniq_dev@localhost:5432/carboniq_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev_jwt_secret_change_me_in_prod_minimum_32_chars
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_me_in_prod_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# SMTP (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025

# Google Gemini AI (leave empty for mock mode)
GEMINI_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
